# ============================================
# MEGA CRM — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# ============================================

# Servidor
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://megacrm_user:senha_forte_aqui@localhost:5432/megacrm
DB_USER=megacrm_user
DB_PASSWORD=senha_forte_aqui

# Redis
REDIS_URL=redis://localhost:6379

# Autenticação
JWT_SECRET=troque_por_uma_string_aleatoria_longa_minimo_64_caracteres_segura

# Evolution API
EVOLUTION_API_URL=https://sua-evolution.com
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_WEBHOOK_SECRET=secret_para_validacao_hmac
EVOLUTION_INSTANCE=mega-whatsapp

# n8n (roda separado na VPS)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/mega-crm-message

# Secret interno — usado pelo n8n para chamar /api/conversations/:id/bot-reply
# O n8n envia no header x-internal-secret. Gere um valor aleatório forte.
INTERNAL_SECRET=troque_por_string_aleatoria_min_16_chars

# Migrations automáticas no startup (true|false)
# Em produção, recomenda-se false e rodar manualmente via Coolify/SSH
AUTO_MIGRATE=true
